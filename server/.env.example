# Environment Variables for Expense Tracker
# Copy this file to .env and fill in the values

# Server Configuration
PORT=5001
NODE_ENV=production

# JWT Secret - IMPORTANT: Change this to a secure random string in production
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-key-change-this-in-production

# Database Configuration (SQLite)
# On Render, the database will be stored in /opt/render/project/data/
# Locally, it will be stored in the server directory
